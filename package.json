{
  "name": "@featrix/sphere-viewer",
  "version": "1.0.0",
  "description": "Embeddable 3D sphere data visualization component using Three.js and React",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "env-cmd -f .env.dev next dev",
    "build": "next build",
    "build:embed": "webpack --mode production",
    "build:package": "npm run build:types && npm run build:esm && npm run build:cjs",
    "build:types": "tsc --project tsconfig.package.json --emitDeclarationOnly",
    "build:esm": "webpack --config webpack.package.js --env module=esm",
    "build:cjs": "webpack --config webpack.package.js --env module=cjs",
    "build:all": "npm run build && npm run build:embed && npm run build:package",
    "start": "next start",
    "lint": "next lint",
    "prepublishOnly": "npm run build:package"
  },
  "keywords": [
    "react",
    "threejs",
    "3d",
    "visualization",
    "sphere",
    "data-viz",
    "embeddable",
    "component"
  ],
  "author": "Featrix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Featrix/sphereviewer.git"
  },
  "homepage": "https://github.com/Featrix/sphereviewer#readme",
  "bugs": {
    "url": "https://github.com/Featrix/sphereviewer/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.1.5",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "three": "^0.174.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.174.0",
    "css-loader": "^6.11.0",
    "eslint": "^8",
    "eslint-config-next": "15.0.3",
    "postcss": "^8",
    "postcss-loader": "^7.3.3",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.2",
    "typescript": "^5",
    "webpack": "^5.100.2",
    "webpack-cli": "^5.1.4"
  }
}
